<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#21493f" />
    <title>KOINORI 주일 룸 예약</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="mobile-app public-app">
    <main class="page-shell">
      <header class="top-bar">
        <button
          type="button"
          class="brand-button"
          id="admin-secret-trigger"
          aria-label="KOINORI 관리자 열기"
        >
          <span class="brand-wordmark">KOINORI</span>
          <span class="brand-copy">
            <strong>주일 룸 예약</strong>
            <small><%= selectedDateLabel %> 자동 선택</small>
          </span>
        </button>
      </header>

      <% if (flashMessage) { %>
        <div class="flash flash-<%= flashLevel %>"><%= flashMessage %></div>
      <% } %>

      <section
        class="page-card intro-page <%= initialPage === 'intro' ? 'is-active' : '' %>"
        data-page="intro"
      >
        <article class="hero-card intro-hero-card">
          <p class="eyebrow">SUNDAY ROOM BOOKING</p>
          <h1>이번 주 주일 룸 예약</h1>

          <div class="hero-meta">
            <div>
              <span>예약 대상</span>
              <strong><%= selectedDateLabel %></strong>
            </div>
            <div>
              <span>예약 오픈</span>
              <strong><%= bookingOpenAtLabel %></strong>
            </div>
            <div>
              <span>현재 시각</span>
              <strong id="live-current-time"><%= currentTimeLabel %></strong>
            </div>
          </div>

          <div
            class="status-banner status-<%= bookingStatus.kind %>"
            id="booking-status-banner"
          >
            <%= bookingStatus.message %>
          </div>

          <div class="summary-strip intro-summary">
            <article class="summary-card">
              <span>확정 예약</span>
              <strong><%= summary.totalConfirmed %></strong>
            </article>
            <article class="summary-card">
              <span>대기 팀</span>
              <strong><%= summary.totalWaitlisted %></strong>
            </article>
            <article class="summary-card">
              <span>남은 방</span>
              <strong><%= summary.remainingAssignments %></strong>
            </article>
            <article class="summary-card">
              <span>가동률</span>
              <strong><%= summary.occupancyPercent %>%</strong>
            </article>
          </div>

          <div class="page-actions intro-actions">
            <button
              type="button"
              class="primary-button"
              id="intro-confirm-button"
              data-go-page="room"
              <%= bookingStatus.open ? '' : 'disabled' %>
            >
              확인하고 예약 보기
            </button>
            <a class="secondary-button link-button" href="/status?date=<%= selectedDate %>">현재 예약 현황 보기</a>
          </div>
        </article>
      </section>

      <nav
        class="page-tabs workflow-tabs"
        data-workflow-nav
        aria-label="예약 단계"
        <%= initialPage === 'intro' ? 'hidden' : '' %>
      >
        <button
          type="button"
          class="page-tab <%= initialPage === 'room' ? 'is-active' : '' %>"
          data-go-page="room"
        >
          1. 방
        </button>
        <button
          type="button"
          class="page-tab <%= initialPage === 'slot' ? 'is-active' : '' %>"
          data-go-page="slot"
        >
          2. 시간
        </button>
        <button
          type="button"
          class="page-tab <%= initialPage === 'form' ? 'is-active' : '' %>"
          data-go-page="form"
        >
          3. 신청
        </button>
      </nav>

      <section class="page-card <%= initialPage === 'room' ? 'is-active' : '' %>" data-page="room">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">STEP 1</p>
            <h2>먼저 방을 선택하세요</h2>
          </div>
          <p class="section-guide">방을 고르면 그 방에서 예약 가능한 시간과 대기 가능 시간을 바로 보여줍니다.</p>
        </div>

        <div class="summary-strip compact-summary">
          <article class="summary-card">
            <span>예약 가능한 타임</span>
            <strong><%= summary.openSlotCount %></strong>
          </article>
          <article class="summary-card">
            <span>운영 타임</span>
            <strong><%= summary.reservableSlotCount %></strong>
          </article>
          <article class="summary-card">
            <span>확정 예약</span>
            <strong><%= summary.totalConfirmed %></strong>
          </article>
          <article class="summary-card">
            <span>대기 팀</span>
            <strong><%= summary.totalWaitlisted %></strong>
          </article>
        </div>

        <div class="room-selector-grid">
          <% schedule.rooms.forEach((room) => { %>
            <% const openCount = room.slots.filter((slot) => slot.actionType === 'reserve').length; %>
            <% const waitCount = room.slots.filter((slot) => slot.actionType === 'waitlist').length; %>
            <% const fixedCount = room.slots.filter((slot) => slot.status === 'fixed').length; %>
            <% const closedCount = room.slots.filter((slot) => slot.status === 'closed').length; %>
            <% const interactiveCount = room.slots.filter((slot) => slot.interactive).length; %>
            <% let roomState = 'closed'; %>
            <% let roomBadge = '예약 불가'; %>
            <% let roomAction = '선택 불가'; %>
            <% if (openCount > 0) { %>
              <% roomState = 'open'; %>
              <% roomBadge = `예약 가능 ${openCount}타임`; %>
              <% roomAction = '이 방 시간 보기'; %>
            <% } else if (waitCount > 0) { %>
              <% roomState = 'wait'; %>
              <% roomBadge = '즉시 예약 마감'; %>
              <% roomAction = '대기 가능 시간 보기'; %>
            <% } else if (fixedCount === room.slots.length) { %>
              <% roomState = 'fixed'; %>
              <% roomBadge = '고정 사용'; %>
            <% } else if (closedCount === room.slots.length) { %>
              <% roomState = 'closed'; %>
              <% roomBadge = '운영 안 함'; %>
            <% } %>
            <% const roomDetailParts = []; %>
            <% if (waitCount > 0) { roomDetailParts.push(`대기 가능 ${waitCount}타임`); } %>
            <% if (fixedCount > 0) { roomDetailParts.push(`고정 ${fixedCount}타임`); } %>
            <% if (closedCount > 0) { roomDetailParts.push(`미운영 ${closedCount}타임`); } %>
            <% const operationCount = room.slots.filter((slot) => slot.status !== 'closed').length; %>
            <button
              type="button"
              class="room-pick-card room-pick-card-<%= roomState %> <%= room.id === initialPublicRoomId ? 'is-selected' : '' %>"
              data-select-room="<%= room.id %>"
              <%= interactiveCount > 0 ? '' : 'disabled' %>
            >
              <span class="room-pick-head">
                <strong><%= room.name %></strong>
                <small><%= roomBadge %></small>
              </span>
              <span class="room-pick-stats">
                <span class="room-pick-stat">
                  <span>예약 가능 타임</span>
                  <strong><%= openCount %></strong>
                </span>
                <span class="room-pick-stat">
                  <span>운영 타임</span>
                  <strong><%= operationCount %></strong>
                </span>
              </span>
              <span class="room-pick-detail"><%= roomDetailParts.join(' · ') || '예약 가능한 시간을 확인해 주세요.' %></span>
              <span class="room-pick-action"><%= roomAction %></span>
            </button>
          <% }) %>
        </div>
      </section>

      <section class="page-card <%= initialPage === 'slot' ? 'is-active' : '' %>" data-page="slot">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">STEP 2</p>
            <h2>선택한 방의 시간을 고르세요</h2>
          </div>
          <p class="section-guide">빈 시간은 바로 예약되고, 이미 찬 시간은 대기 신청 여부를 다시 확인합니다.</p>
        </div>

        <div class="selection-banner" id="selected-room-banner">
          <strong>선택한 방 없음</strong>
          <span>먼저 방을 선택해 주세요.</span>
        </div>

        <% schedule.rooms.forEach((room) => { %>
          <section
            class="room-panel"
            data-room-slots="<%= room.id %>"
            <%= room.id === initialPublicRoomId ? '' : 'hidden' %>
          >
            <div class="choice-grid">
              <% room.slots.forEach((slot) => { %>
                <button
                  type="button"
                  class="slot-card slot-card-<%= slot.status %> <%= room.id === initialPublicRoomId && slot.slot.id === initialPublicSlotId ? 'is-selected' : '' %>"
                  data-select-slot="<%= slot.slot.id %>"
                  data-room-id="<%= room.id %>"
                  <%= slot.interactive ? '' : 'disabled' %>
                >
                  <span class="slot-card-head">
                    <strong><%= slot.slot.label %></strong>
                    <small><%= slot.slot.timeRange %></small>
                  </span>
                  <span class="slot-card-badge"><%= slot.actionLabel %></span>
                  <span class="slot-card-title"><%= slot.title %></span>
                  <span class="slot-card-detail"><%= slot.detail %></span>
                </button>
              <% }) %>
            </div>
          </section>
        <% }) %>

        <div class="page-actions compact-actions">
          <button type="button" class="secondary-button" data-go-page="room">방 다시 선택</button>
        </div>
      </section>

      <section class="page-card <%= initialPage === 'form' ? 'is-active' : '' %>" data-page="form">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">STEP 3</p>
            <h2>신청 정보를 적어 주세요</h2>
          </div>
          <p class="section-guide">서버가 제출 시점의 선착순을 확인합니다. 먼저 접수된 팀이 있으면 대기 등록 여부를 다시 묻습니다.</p>
        </div>

        <div class="selection-summary compact-summary-card" id="booking-summary">
          <div>
            <span>예약 날짜</span>
            <strong><%= selectedDateLabel %></strong>
          </div>
          <div>
            <span>선택 방</span>
            <strong id="summary-room-label">선택 전</strong>
          </div>
          <div>
            <span>선택 시간</span>
            <strong id="summary-slot-label">선택 전</strong>
          </div>
          <div>
            <span>접수 방식</span>
            <strong id="summary-mode-label">선택 전</strong>
          </div>
        </div>

        <div class="helper-box compact-helper" id="form-guidance-box">
          예약 가능한 시간을 고르면 바로 예약 요청이 들어갑니다.
        </div>

        <div class="confirm-prompt" id="waitlist-confirmation" hidden>
          <strong>즉시 예약은 마감되었습니다.</strong>
          <p id="waitlist-confirm-message">다른 시간이 먼저 확정되었습니다. 대기 등록 여부를 확인해 주세요.</p>
        </div>

        <form class="booking-form compact-form" id="booking-form" method="post" action="/reservations">
          <input id="reservation-date-input" type="hidden" name="reservationDate" value="<%= formValues.reservationDate %>" />
          <input id="slot-id-input" type="hidden" name="slotId" value="<%= formValues.slotId %>" />
          <input id="room-id-input" type="hidden" name="roomId" value="<%= formValues.roomId || '' %>" />
          <input id="waitlist-consent-input" type="hidden" name="waitlistConsent" value="0" />

          <label class="field">
            <span>공동체 이름</span>
            <input
              type="text"
              name="communityName"
              value="<%= formValues.communityName %>"
              placeholder="예: 김선목속"
              required
            />
          </label>

          <label class="field">
            <span>신청자 이름</span>
            <input
              type="text"
              name="requesterName"
              value="<%= formValues.requesterName %>"
              placeholder="예: 홍길동"
              required
            />
          </label>

          <label class="field">
            <span>인원 수</span>
            <input
              id="attendees-input"
              type="number"
              name="attendees"
              min="<%= minAttendees %>"
              step="1"
              value="<%= formValues.attendees %>"
              required
            />
            <small class="field-error" id="attendees-error" hidden>최소 <%= minAttendees %>명부터 신청할 수 있습니다.</small>
          </label>

          <label class="field">
            <span>연락처</span>
            <input
              id="contact-input"
              type="text"
              name="contact"
              value="<%= formValues.contact %>"
              placeholder="문자나 전화 가능한 번호"
              required
            />
          </label>

          <label class="field field-wide">
            <span>메모</span>
            <textarea name="note" rows="3" placeholder="브레이크 타임, 요청 사항 등을 적어 주세요."><%= formValues.note %></textarea>
          </label>

          <div class="page-actions compact-actions">
            <button type="button" class="secondary-button" data-go-page="slot">시간 다시 선택</button>
            <button
              type="submit"
              class="primary-button"
              id="booking-submit-button"
              <%= bookingStatus.open ? '' : 'disabled' %>
            >
              예약 신청하기
            </button>
          </div>
        </form>
      </section>
    </main>

    <div class="modal-shell" id="admin-access-modal" hidden>
      <div class="modal-card">
        <button type="button" class="modal-close" id="admin-modal-close" aria-label="닫기">닫기</button>
        <div class="modal-brand">
          <span class="brand-wordmark modal-wordmark">KOINORI</span>
          <p class="eyebrow">관리자 전용</p>
        </div>
        <h2>운영 화면 로그인</h2>
        <p class="modal-text">운영 비밀번호를 입력하면 관리자 화면으로 이동합니다.</p>

        <form method="post" action="/admin/login" class="login-form">
          <input type="hidden" name="returnTo" value="<%= adminReturnTo %>" />

          <label class="field">
            <span>관리 비밀번호</span>
            <input
              type="password"
              name="adminKey"
              inputmode="numeric"
              autocomplete="current-password"
              required
            />
          </label>

          <button type="submit" class="primary-button">관리자 들어가기</button>
        </form>
      </div>
    </div>

    <div class="modal-shell" id="waitlist-modal" hidden>
      <div class="modal-card">
        <button type="button" class="modal-close" id="waitlist-modal-close" aria-label="닫기">닫기</button>
        <div class="modal-brand">
          <span class="brand-wordmark modal-wordmark">KOINORI</span>
          <p class="eyebrow">WAITLIST</p>
        </div>
        <h2>대기 명단에 올릴까요?</h2>
        <p class="modal-text" id="waitlist-modal-message">
          이 시간은 먼저 접수된 팀이 있어 대기 여부를 먼저 확인합니다.
        </p>
        <div class="page-actions compact-actions">
          <button type="button" class="secondary-button" id="waitlist-decline-button">다른 시간 보기</button>
          <button type="button" class="primary-button" id="waitlist-confirm-button">대기 신청하기</button>
        </div>
      </div>
    </div>

    <script id="public-state" type="application/json"><%- serializedPublicState %></script>
    <script src="/app.js" defer></script>
  </body>
</html>
