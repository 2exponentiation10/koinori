<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#204f47" />
    <title>KOINORI 주일 룸 예약</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="mobile-app public-app">
    <main class="page-shell">
      <header class="app-header">
        <button
          type="button"
          class="brand-button"
          id="admin-secret-trigger"
          aria-label="KOINORI 관리자 열기"
        >
          <img src="/koinori-logo.svg" alt="KOINORI 로고" class="brand-logo" />
          <span class="brand-copy">
            <strong>KOINORI</strong>
            <small>주일 룸 예약</small>
          </span>
        </button>

        <article class="hero-card">
          <p class="eyebrow">모바일 예약</p>
          <h1>방을 직접 고르고 신청하세요</h1>
          <p class="hero-text">
            긴 스크롤 대신 순서대로 넘어가는 화면입니다. 날짜를 고르고, 타임을 누르고, 원하는
            방을 선택하면 바로 신청할 수 있습니다.
          </p>
          <div class="hero-meta">
            <div>
              <span>선택한 날짜</span>
              <strong><%= selectedDateLabel %></strong>
            </div>
            <div>
              <span>현재 시각</span>
              <strong><%= currentTimeLabel %></strong>
            </div>
            <div>
              <span>예약 오픈</span>
              <strong><%= bookingOpenAtLabel %></strong>
            </div>
          </div>
          <div class="status-banner status-<%= bookingStatus.kind %>"><%= bookingStatus.message %></div>
        </article>
      </header>

      <% if (flashMessage) { %>
        <div class="flash flash-<%= flashLevel %>"><%= flashMessage %></div>
      <% } %>

      <nav class="page-tabs" aria-label="예약 단계">
        <button type="button" class="page-tab is-active" data-go-page="date">1. 날짜</button>
        <button type="button" class="page-tab" data-go-page="slot">2. 타임</button>
        <button type="button" class="page-tab" data-go-page="room">3. 방</button>
        <button type="button" class="page-tab" data-go-page="form">4. 신청</button>
        <button type="button" class="page-tab" data-go-page="board">5. 현황</button>
      </nav>

      <section class="page-card is-active" data-page="date">
        <div class="section-heading">
          <div>
            <p class="eyebrow">STEP 1</p>
            <h2>예약할 주일을 고르세요</h2>
          </div>
          <p class="section-guide">목요일 오전 10시 이후부터 선착순 접수됩니다.</p>
        </div>

        <div class="choice-grid choice-grid-dates">
          <% sundayOptions.forEach((option) => { %>
            <a
              href="/?date=<%= option.date %>"
              class="choice-card <%= option.selected ? 'choice-card-active' : '' %>"
            >
              <strong><%= option.label %></strong>
              <span>예약 오픈: <%= option.openAtLabel %></span>
            </a>
          <% }) %>
        </div>

        <div class="rule-list">
          <% noticeItems.forEach((notice) => { %>
            <article class="rule-item">
              <strong>안내</strong>
              <p><%= notice %></p>
            </article>
          <% }) %>
        </div>

        <div class="page-actions">
          <button type="button" class="primary-button" data-go-page="slot">다음: 타임 고르기</button>
        </div>
      </section>

      <section class="page-card" data-page="slot">
        <div class="section-heading">
          <div>
            <p class="eyebrow">STEP 2</p>
            <h2>이용 타임을 선택하세요</h2>
          </div>
          <p class="section-guide">예약 가능, 만석, 고정 사용 상태를 바로 확인할 수 있습니다.</p>
        </div>

        <div class="summary-strip">
          <article class="summary-card">
            <span>확정 예약</span>
            <strong><%= summary.totalConfirmed %></strong>
          </article>
          <article class="summary-card">
            <span>대기 팀</span>
            <strong><%= summary.totalWaitlisted %></strong>
          </article>
          <article class="summary-card">
            <span>남은 방</span>
            <strong><%= summary.remainingAssignments %></strong>
          </article>
        </div>

        <div class="choice-grid">
          <% slotDetails.forEach((slot) => { %>
            <button
              type="button"
              class="slot-card slot-card-<%= slot.status %>"
              data-slot-id="<%= slot.id %>"
              data-slot-bookable="<%= slot.bookable ? '1' : '0' %>"
              data-slot-waitlist="<%= slot.canWaitlist ? '1' : '0' %>"
              <%= slot.bookable ? '' : 'disabled' %>
            >
              <span class="slot-card-head">
                <strong><%= slot.label %></strong>
                <small><%= slot.timeRange %></small>
              </span>
              <span class="slot-card-badge"><%= slot.availabilityLabel %></span>
              <span class="slot-card-detail"><%= slot.detailLabel %></span>
              <span class="slot-card-action"><%= slot.actionLabel %></span>
            </button>
          <% }) %>
        </div>

        <div class="page-actions dual-actions">
          <button type="button" class="secondary-button" data-go-page="date">이전</button>
          <button type="button" class="primary-button" data-go-page="room">다음: 방 고르기</button>
        </div>
      </section>

      <section class="page-card" data-page="room">
        <div class="section-heading">
          <div>
            <p class="eyebrow">STEP 3</p>
            <h2>방을 선택하세요</h2>
          </div>
          <p class="section-guide" id="room-step-guide">타임을 먼저 선택하면 해당 타임의 방 목록이 나옵니다.</p>
        </div>

        <div class="selection-banner" id="selected-slot-banner">
          <strong>선택한 타임 없음</strong>
          <span>먼저 위 단계에서 타임을 선택해 주세요.</span>
        </div>

        <% slotDetails.forEach((slot) => { %>
          <section class="room-panel" data-slot-rooms="<%= slot.id %>" <%= slot.id === defaultSlotId ? '' : 'hidden' %>>
            <div class="room-panel-header">
              <h3><%= slot.label %> <span><%= slot.timeRange %></span></h3>
              <p><%= slot.detailLabel %></p>
            </div>

            <% if (!slot.bookable) { %>
              <div class="empty-state">
                이 타임은 현재 예약을 받지 않습니다. 관리자 설정에서 예약 가능 방을 열어야 신청할 수
                있습니다.
              </div>
            <% } else { %>
              <div class="choice-grid choice-grid-rooms">
                <% slot.rooms.forEach((room) => { %>
                  <button
                    type="button"
                    class="room-card room-card-<%= room.status %>"
                    data-slot-room-id="<%= room.roomId %>"
                    data-slot-id="<%= slot.id %>"
                    data-room-selectable="<%= room.selectable ? '1' : '0' %>"
                    <%= room.selectable ? '' : 'disabled' %>
                  >
                    <span class="room-card-head">
                      <strong><%= room.roomName %></strong>
                      <small><%= room.status === 'available' ? '선택 가능' : room.status === 'reserved' ? '이미 예약됨' : room.status === 'fixed' ? '고정 사용' : '운영 안 함' %></small>
                    </span>
                    <span class="room-card-title"><%= room.title %></span>
                    <span class="room-card-detail"><%= room.detail %></span>
                  </button>
                <% }) %>
              </div>

              <% if (slot.canWaitlist) { %>
                <button type="button" class="waitlist-button" data-waitlist-slot="<%= slot.id %>">
                  방이 모두 찼습니다. 이 타임 대기 신청으로 계속하기
                </button>
              <% } %>
            <% } %>
          </section>
        <% }) %>

        <div class="page-actions dual-actions">
          <button type="button" class="secondary-button" data-go-page="slot">이전</button>
          <button type="button" class="primary-button" data-go-page="form">다음: 신청서 작성</button>
        </div>
      </section>

      <section class="page-card" data-page="form">
        <div class="section-heading">
          <div>
            <p class="eyebrow">STEP 4</p>
            <h2>신청 정보를 입력하세요</h2>
          </div>
          <p class="section-guide">고령 사용자도 쉽게 보이도록 큰 입력창과 확인 문구를 넣었습니다.</p>
        </div>

        <div class="selection-summary" id="booking-summary">
          <div>
            <span>예약 날짜</span>
            <strong><%= selectedDateLabel %></strong>
          </div>
          <div>
            <span>선택 타임</span>
            <strong id="summary-slot-label">선택 전</strong>
          </div>
          <div>
            <span>선택 방</span>
            <strong id="summary-room-label">선택 전</strong>
          </div>
        </div>

        <form class="booking-form" id="booking-form" method="post" action="/reservations">
          <input id="reservation-date-input" type="hidden" name="reservationDate" value="<%= formValues.reservationDate %>" />
          <input id="slot-id-input" type="hidden" name="slotId" value="<%= formValues.slotId %>" />
          <input id="room-id-input" type="hidden" name="roomId" value="<%= formValues.roomId || '' %>" />
          <input id="join-waitlist-input" type="hidden" name="joinWaitlist" value="<%= formValues.joinWaitlist %>" />

          <label class="field">
            <span>공동체 이름</span>
            <input
              type="text"
              name="communityName"
              value="<%= formValues.communityName %>"
              placeholder="예: 김선목속"
              required
            />
          </label>

          <label class="field">
            <span>신청자 이름</span>
            <input
              type="text"
              name="requesterName"
              value="<%= formValues.requesterName %>"
              placeholder="예: 홍길동"
              required
            />
          </label>

          <label class="field">
            <span>인원 수</span>
            <input
              type="number"
              name="attendees"
              min="<%= minAttendees %>"
              value="<%= formValues.attendees %>"
              required
            />
          </label>

          <label class="field">
            <span>연락처</span>
            <input
              type="text"
              name="contact"
              value="<%= formValues.contact %>"
              placeholder="문자나 전화 가능한 번호"
            />
          </label>

          <label class="field field-wide">
            <span>메모</span>
            <textarea name="note" rows="4" placeholder="브레이크 타임, 추가 전달사항 등을 적어 주세요."><%= formValues.note %></textarea>
          </label>

          <div class="helper-box">
            자리가 있는 타임은 선택한 방으로 바로 예약됩니다. 방이 모두 찬 타임은 대기 신청으로
            접수됩니다.
          </div>

          <div class="page-actions dual-actions">
            <button type="button" class="secondary-button" data-go-page="room">이전</button>
            <button
              type="submit"
              class="primary-button"
              id="booking-submit-button"
              <%= bookingStatus.open ? '' : 'disabled' %>
            >
              예약 신청하기
            </button>
          </div>
        </form>
      </section>

      <section class="page-card" data-page="board">
        <div class="section-heading">
          <div>
            <p class="eyebrow">STEP 5</p>
            <h2>현재 예약 현황</h2>
          </div>
          <p class="section-guide">한 번에 한 타임씩 보여주어 방 상태를 보기 쉽게 정리했습니다.</p>
        </div>

        <div class="slot-chip-row">
          <% slotDetails.forEach((slot) => { %>
            <button type="button" class="slot-chip-button <%= slot.id === defaultSlotId ? 'is-active' : '' %>" data-board-slot-tab="<%= slot.id %>">
              <strong><%= slot.label %></strong>
              <span><%= slot.timeRange %></span>
            </button>
          <% }) %>
        </div>

        <% slotDetails.forEach((slot) => { %>
          <section class="board-slot-panel <%= slot.id === defaultSlotId ? 'is-active' : '' %>" data-board-slot="<%= slot.id %>">
            <div class="selection-banner">
              <strong><%= slot.label %> <%= slot.timeRange %></strong>
              <span><%= slot.detailLabel %></span>
            </div>

            <div class="choice-grid choice-grid-rooms">
              <% slot.rooms.forEach((room) => { %>
                <article class="board-room-card board-room-card-<%= room.status %>">
                  <span class="room-card-head">
                    <strong><%= room.roomName %></strong>
                    <small><%= room.status === 'available' ? '예약 가능' : room.status === 'reserved' ? '예약 중' : room.status === 'fixed' ? '고정 사용' : '운영 안 함' %></small>
                  </span>
                  <span class="room-card-title"><%= room.title %></span>
                  <span class="room-card-detail"><%= room.detail %></span>
                </article>
              <% }) %>
            </div>

            <% if (slot.waitlistItems.length) { %>
              <div class="waitlist-panel">
                <h3>대기 명단</h3>
                <ol>
                  <% slot.waitlistItems.forEach((reservation, index) => { %>
                    <li><%= index + 1 %>. <%= reservation.communityName %> / <%= reservation.requesterName %> / <%= reservation.attendees %>명</li>
                  <% }) %>
                </ol>
              </div>
            <% } %>
          </section>
        <% }) %>

        <div class="page-actions dual-actions">
          <button type="button" class="secondary-button" data-go-page="form">이전</button>
          <button type="button" class="primary-button" data-go-page="date">처음으로</button>
        </div>
      </section>
    </main>

    <div class="modal-shell" id="admin-access-modal" hidden>
      <div class="modal-card">
        <button type="button" class="modal-close" id="admin-modal-close" aria-label="닫기">닫기</button>
        <img src="/koinori-logo.svg" alt="KOINORI 로고" class="modal-logo" />
        <p class="eyebrow">관리자 전용</p>
        <h2>운영 화면 열기</h2>
        <p class="modal-text">KOINORI 로고를 10번 터치하면 이 화면이 열립니다. 비밀번호는 숫자 4자리입니다.</p>

        <form method="post" action="/admin/login" class="login-form">
          <input type="hidden" name="returnTo" value="<%= adminReturnTo %>" />

          <label class="field">
            <span>관리 비밀번호</span>
            <input
              type="password"
              name="adminKey"
              inputmode="numeric"
              autocomplete="current-password"
              placeholder="0191"
              required
            />
          </label>

          <button type="submit" class="primary-button">관리자 들어가기</button>
        </form>
      </div>
    </div>

    <script id="public-state" type="application/json"><%- serializedPublicState %></script>
    <script src="/app.js" defer></script>
  </body>
</html>
