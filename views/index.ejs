<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#21493f" />
    <title>KOINORI 주일 룸 예약</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="mobile-app public-app">
    <main class="page-shell">
      <header class="app-header">
        <button
          type="button"
          class="brand-button"
          id="admin-secret-trigger"
          aria-label="KOINORI 관리자 열기"
        >
          <span class="brand-wordmark">KOINORI</span>
          <span class="brand-copy">
            <strong>주일 룸 예약</strong>
            <small><%= selectedDateLabel %> 자동 선택</small>
          </span>
        </button>

        <article class="hero-card">
          <p class="eyebrow">SUNDAY BOOKING</p>
          <h1>타임과 방만 고르면 됩니다</h1>
          <p class="hero-text">
            예약 날짜는 이번 주 주일로 자동 선택됩니다. 긴 스크롤 대신 `타임 -> 방 -> 신청 -> 현황`
            순서로만 진행합니다.
          </p>

          <div class="hero-meta compact-meta">
            <div>
              <span>예약 대상</span>
              <strong><%= selectedDateLabel %></strong>
            </div>
            <div>
              <span>예약 오픈</span>
              <strong><%= bookingOpenAtLabel %></strong>
            </div>
            <div>
              <span>현재 시각</span>
              <strong><%= currentTimeLabel %></strong>
            </div>
          </div>

          <div class="status-banner status-<%= bookingStatus.kind %>"><%= bookingStatus.message %></div>

          <div class="mini-rule-row">
            <% noticeItems.slice(0, 3).forEach((notice) => { %>
              <article class="mini-rule-card"><%= notice %></article>
            <% }) %>
          </div>
        </article>
      </header>

      <% if (flashMessage) { %>
        <div class="flash flash-<%= flashLevel %>"><%= flashMessage %></div>
      <% } %>

      <nav class="page-tabs" aria-label="예약 단계">
        <button type="button" class="page-tab is-active" data-go-page="slot">1. 타임</button>
        <button type="button" class="page-tab" data-go-page="room">2. 방</button>
        <button type="button" class="page-tab" data-go-page="form">3. 신청</button>
        <button type="button" class="page-tab" data-go-page="board">4. 현황</button>
      </nav>

      <section class="page-card is-active" data-page="slot">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">STEP 1</p>
            <h2>타임을 선택하세요</h2>
          </div>
          <p class="section-guide">타임을 누르면 바로 방 목록으로 넘어갑니다.</p>
        </div>

        <div class="summary-strip compact-summary">
          <article class="summary-card">
            <span>확정 예약</span>
            <strong><%= summary.totalConfirmed %></strong>
          </article>
          <article class="summary-card">
            <span>대기 팀</span>
            <strong><%= summary.totalWaitlisted %></strong>
          </article>
          <article class="summary-card">
            <span>남은 방</span>
            <strong><%= summary.remainingAssignments %></strong>
          </article>
          <article class="summary-card">
            <span>가동률</span>
            <strong><%= summary.occupancyPercent %>%</strong>
          </article>
        </div>

        <div class="choice-grid">
          <% slotDetails.forEach((slot) => { %>
            <button
              type="button"
              class="slot-card slot-card-<%= slot.status %>"
              data-slot-id="<%= slot.id %>"
              <%= slot.bookable ? '' : 'disabled' %>
            >
              <span class="slot-card-head">
                <strong><%= slot.label %></strong>
                <small><%= slot.timeRange %></small>
              </span>
              <span class="slot-card-badge"><%= slot.availabilityLabel %></span>
              <span class="slot-card-detail"><%= slot.detailLabel %></span>
              <span class="slot-card-action"><%= slot.actionLabel %></span>
            </button>
          <% }) %>
        </div>
      </section>

      <section class="page-card" data-page="room">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">STEP 2</p>
            <h2>방을 선택하세요</h2>
          </div>
          <p class="section-guide" id="room-step-guide">타임을 먼저 선택하면 방 목록이 보입니다.</p>
        </div>

        <div class="selection-banner" id="selected-slot-banner">
          <strong>선택한 타임 없음</strong>
          <span>먼저 타임을 선택해 주세요.</span>
        </div>

        <% slotDetails.forEach((slot) => { %>
          <section class="room-panel" data-slot-rooms="<%= slot.id %>" <%= slot.id === defaultSlotId ? '' : 'hidden' %>>
            <div class="choice-grid choice-grid-rooms">
              <% slot.rooms.forEach((room) => { %>
                <button
                  type="button"
                  class="room-card room-card-<%= room.status %>"
                  data-slot-room-id="<%= room.roomId %>"
                  data-slot-id="<%= slot.id %>"
                  data-room-action="<%= room.actionType %>"
                  <%= room.interactive ? '' : 'disabled' %>
                >
                  <span class="room-card-head">
                    <strong><%= room.roomName %></strong>
                    <small><%= room.actionLabel %></small>
                  </span>
                  <span class="room-card-title"><%= room.title %></span>
                  <span class="room-card-detail"><%= room.detail %></span>
                </button>
              <% }) %>
            </div>
          </section>
        <% }) %>

        <div class="page-actions compact-actions">
          <button type="button" class="secondary-button" data-go-page="slot">타임 다시 보기</button>
        </div>
      </section>

      <section class="page-card" data-page="form">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">STEP 3</p>
            <h2>신청 정보를 적어 주세요</h2>
          </div>
          <p class="section-guide">선택한 방이 비어 있으면 예약, 이미 사용 중이면 해당 방 대기로 접수됩니다.</p>
        </div>

        <div class="selection-summary compact-summary-card" id="booking-summary">
          <div>
            <span>예약 날짜</span>
            <strong><%= selectedDateLabel %></strong>
          </div>
          <div>
            <span>선택 타임</span>
            <strong id="summary-slot-label">선택 전</strong>
          </div>
          <div>
            <span>선택 방</span>
            <strong id="summary-room-label">선택 전</strong>
          </div>
          <div>
            <span>접수 방식</span>
            <strong id="summary-mode-label">선택 전</strong>
          </div>
        </div>

        <form class="booking-form compact-form" id="booking-form" method="post" action="/reservations">
          <input id="reservation-date-input" type="hidden" name="reservationDate" value="<%= formValues.reservationDate %>" />
          <input id="slot-id-input" type="hidden" name="slotId" value="<%= formValues.slotId %>" />
          <input id="room-id-input" type="hidden" name="roomId" value="<%= formValues.roomId || '' %>" />

          <label class="field">
            <span>공동체 이름</span>
            <input
              type="text"
              name="communityName"
              value="<%= formValues.communityName %>"
              placeholder="예: 김선목속"
              required
            />
          </label>

          <label class="field">
            <span>신청자 이름</span>
            <input
              type="text"
              name="requesterName"
              value="<%= formValues.requesterName %>"
              placeholder="예: 홍길동"
              required
            />
          </label>

          <label class="field">
            <span>인원 수</span>
            <input
              type="number"
              name="attendees"
              min="<%= minAttendees %>"
              value="<%= formValues.attendees %>"
              required
            />
          </label>

          <label class="field">
            <span>연락처</span>
            <input
              type="text"
              name="contact"
              value="<%= formValues.contact %>"
              placeholder="문자나 전화 가능한 번호"
            />
          </label>

          <label class="field field-wide">
            <span>메모</span>
            <textarea name="note" rows="3" placeholder="브레이크 타임, 요청 사항 등을 적어 주세요."><%= formValues.note %></textarea>
          </label>

          <div class="helper-box compact-helper">
            이미 사용 중인 방을 선택하면 그 방의 대기 명단에 선착순으로 등록되고, 취소가 나오면 같은
            방으로 자동 승격됩니다.
          </div>

          <div class="page-actions compact-actions">
            <button type="button" class="secondary-button" data-go-page="room">방 다시 선택</button>
            <button
              type="submit"
              class="primary-button"
              id="booking-submit-button"
              <%= bookingStatus.open ? '' : 'disabled' %>
            >
              예약 신청하기
            </button>
          </div>
        </form>
      </section>

      <section class="page-card" data-page="board">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">STEP 4</p>
            <h2>예약 현황</h2>
          </div>
          <p class="section-guide">타임별로 각 방의 사용 상태와 대기 순서를 함께 볼 수 있습니다.</p>
        </div>

        <div class="slot-chip-row">
          <% slotDetails.forEach((slot) => { %>
            <button type="button" class="slot-chip-button <%= slot.id === defaultSlotId ? 'is-active' : '' %>" data-board-slot-tab="<%= slot.id %>">
              <strong><%= slot.label %></strong>
              <span><%= slot.timeRange %></span>
            </button>
          <% }) %>
        </div>

        <% slotDetails.forEach((slot) => { %>
          <section class="board-slot-panel <%= slot.id === defaultSlotId ? 'is-active' : '' %>" data-board-slot="<%= slot.id %>">
            <div class="selection-banner compact-banner">
              <strong><%= slot.label %> <%= slot.timeRange %></strong>
              <span><%= slot.detailLabel %></span>
            </div>

            <div class="choice-grid choice-grid-rooms">
              <% slot.rooms.forEach((room) => { %>
                <article class="board-room-card board-room-card-<%= room.status %>">
                  <span class="room-card-head">
                    <strong><%= room.roomName %></strong>
                    <small><%= room.status === 'available' ? '예약 가능' : room.status === 'reserved' ? '예약 중' : room.status === 'fixed' ? '고정 사용' : '운영 안 함' %></small>
                  </span>
                  <span class="room-card-title"><%= room.title %></span>
                  <span class="room-card-detail"><%= room.detail %></span>

                  <% if (room.waitlistItems.length) { %>
                    <ol class="inline-waitlist">
                      <% room.waitlistItems.forEach((reservation, index) => { %>
                        <li><%= index + 1 %>. <%= reservation.communityName %> / <%= reservation.requesterName %></li>
                      <% }) %>
                    </ol>
                  <% } %>
                </article>
              <% }) %>
            </div>

            <% if (slot.legacyWaitlistItems.length) { %>
              <div class="waitlist-panel">
                <h3>방 미지정 대기</h3>
                <ol>
                  <% slot.legacyWaitlistItems.forEach((reservation, index) => { %>
                    <li><%= index + 1 %>. <%= reservation.communityName %> / <%= reservation.requesterName %></li>
                  <% }) %>
                </ol>
              </div>
            <% } %>
          </section>
        <% }) %>
      </section>
    </main>

    <div class="modal-shell" id="admin-access-modal" hidden>
      <div class="modal-card">
        <button type="button" class="modal-close" id="admin-modal-close" aria-label="닫기">닫기</button>
        <div class="modal-brand">
          <span class="brand-wordmark modal-wordmark">KOINORI</span>
          <p class="eyebrow">관리자 전용</p>
        </div>
        <h2>운영 화면 로그인</h2>
        <p class="modal-text">운영 비밀번호를 입력하면 관리자 화면으로 이동합니다.</p>

        <form method="post" action="/admin/login" class="login-form">
          <input type="hidden" name="returnTo" value="<%= adminReturnTo %>" />

          <label class="field">
            <span>관리 비밀번호</span>
            <input
              type="password"
              name="adminKey"
              inputmode="numeric"
              autocomplete="current-password"
              required
            />
          </label>

          <button type="submit" class="primary-button">관리자 들어가기</button>
        </form>
      </div>
    </div>

    <script id="public-state" type="application/json"><%- serializedPublicState %></script>
    <script src="/app.js" defer></script>
  </body>
</html>
