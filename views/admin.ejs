<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#6b2d2c" />
    <title>KOINORI 관리자</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="mobile-app admin-app">
    <main class="page-shell">
      <header class="app-header admin-header">
        <div class="brand-panel">
          <span class="brand-wordmark admin-wordmark">KOINORI</span>
          <div class="brand-copy">
            <strong>운영 화면</strong>
            <small><%= selectedDateLabel %> 운영 기준</small>
          </div>
        </div>

        <article class="hero-card admin-hero-card">
          <div class="hero-row">
            <div>
              <p class="eyebrow">OPS DASHBOARD</p>
              <h1><%= selectedDateLabel %></h1>
            </div>
            <% if (adminAuthEnabled) { %>
              <form method="post" action="/admin/logout">
                <button type="submit" class="secondary-button">로그아웃</button>
              </form>
            <% } %>
          </div>

          <p class="hero-text">예약자 명단, 방 상태 설정, 방별 대기 명단을 모바일에서 짧은 화면으로 운영할 수 있게 정리했습니다.</p>

          <div class="hero-meta compact-meta">
            <div>
              <span>현재 시각</span>
              <strong><%= currentTimeLabel %></strong>
            </div>
            <div>
              <span>예약 오픈</span>
              <strong><%= bookingOpenAtLabel %></strong>
            </div>
          </div>

          <div class="status-banner status-<%= bookingStatus.kind %>"><%= bookingStatus.message %></div>
        </article>
      </header>

      <% if (flashMessage) { %>
        <div class="flash flash-<%= flashLevel %>"><%= flashMessage %></div>
      <% } %>

      <section class="page-card compact-card">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">DATE</p>
            <h2>운영 날짜</h2>
          </div>
        </div>

        <form class="inline-form compact-form" method="get" action="/admin">
          <label class="field">
            <span>운영 날짜</span>
            <input type="date" name="date" value="<%= selectedDate %>" required />
          </label>
          <button type="submit" class="primary-button">이동</button>
        </form>

        <div class="choice-grid choice-grid-dates">
          <% sundayOptions.forEach((option) => { %>
            <a
              href="/admin?date=<%= option.date %>"
              class="choice-card <%= option.selected ? 'choice-card-active' : '' %>"
            >
              <strong><%= option.label %></strong>
              <span>오픈 <%= option.openAtLabel %></span>
            </a>
          <% }) %>
        </div>
      </section>

      <nav class="page-tabs" aria-label="관리자 페이지">
        <button type="button" class="page-tab is-active" data-go-page="summary">1. 요약</button>
        <button type="button" class="page-tab" data-go-page="settings">2. 방 설정</button>
        <button type="button" class="page-tab" data-go-page="control">3. 예약자</button>
        <button type="button" class="page-tab" data-go-page="waitlist">4. 대기자</button>
      </nav>

      <section class="page-card is-active compact-card" data-page="summary">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">SUMMARY</p>
            <h2>운영 요약</h2>
          </div>
        </div>

        <div class="summary-strip compact-summary">
          <article class="summary-card">
            <span>확정 예약</span>
            <strong><%= summary.totalConfirmed %></strong>
          </article>
          <article class="summary-card">
            <span>대기 팀</span>
            <strong><%= summary.totalWaitlisted %></strong>
          </article>
          <article class="summary-card">
            <span>남은 방</span>
            <strong><%= summary.remainingAssignments %></strong>
          </article>
          <article class="summary-card">
            <span>가동률</span>
            <strong><%= summary.occupancyPercent %>%</strong>
          </article>
        </div>

        <div class="choice-grid">
          <% slotDetails.forEach((slot) => { %>
            <article class="slot-card slot-card-<%= slot.status %> slot-card-static">
              <span class="slot-card-head">
                <strong><%= slot.label %></strong>
                <small><%= slot.timeRange %></small>
              </span>
              <span class="slot-card-badge"><%= slot.availabilityLabel %></span>
              <span class="slot-card-detail"><%= slot.detailLabel %></span>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="page-card compact-card" data-page="settings">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">SETTINGS</p>
            <h2>방 상태 설정</h2>
          </div>
          <p class="section-guide">저장한 설정은 같은 타임의 다음 주일에도 이어집니다.</p>
        </div>

        <form method="post" action="/admin/settings/booking-open" class="settings-room-meta-form">
          <input type="hidden" name="date" value="<%= selectedDate %>" />

          <div class="selection-banner compact-banner">
            <strong>예약 공개 규칙</strong>
            <span>오픈 요일과 시간을 정하거나, 아예 시간 제한 없이 항상 열리게 할 수 있습니다.</span>
          </div>

          <div class="room-meta-grid">
            <article class="room-meta-card room-meta-card-accent">
              <div class="room-meta-card-head">
                <div>
                  <strong>현재 공개 상태</strong>
                  <small><%= bookingOpenAtLabel %> 기준으로 공개 화면에 표시됩니다.</small>
                </div>
              </div>

              <label class="field room-meta-field">
                <span>예약 제한</span>
                <select name="bookingRestrictionEnabled">
                  <option value="1" <%= bookingRestrictionEnabled ? 'selected' : '' %>>요일/시간 기준으로 오픈</option>
                  <option value="0" <%= !bookingRestrictionEnabled ? 'selected' : '' %>>항상 오픈 (제한 없음)</option>
                </select>
              </label>

              <div class="room-meta-inline-grid">
                <label class="field room-meta-field">
                  <span>오픈 요일</span>
                  <select name="bookingOpenDay">
                    <% bookingWeekdayOptions.forEach((option) => { %>
                      <option value="<%= option.value %>" <%= option.selected ? 'selected' : '' %>><%= option.label %></option>
                    <% }) %>
                  </select>
                </label>

                <label class="field room-meta-field">
                  <span>오픈 시간</span>
                  <input type="time" name="bookingOpenTime" value="<%= bookingOpenTime %>" />
                </label>
              </div>

              <p class="room-meta-hint">
                예: 목요일 10:00 오픈, 또는 필요 시 항상 오픈으로 전환할 수 있습니다.
              </p>
            </article>

          </div>

          <div class="page-actions compact-actions">
            <button type="submit" class="primary-button">예약 공개 규칙 저장</button>
          </div>
        </form>

        <form method="post" action="/admin/rooms" enctype="multipart/form-data" class="settings-room-meta-form room-create-form">
          <input type="hidden" name="date" value="<%= selectedDate %>" />

          <div class="selection-banner compact-banner">
            <strong>새 방 추가</strong>
            <span>추가 즉시 예약 화면과 운영 화면에 반영됩니다.</span>
          </div>

          <div class="room-meta-grid room-meta-grid-single">
            <article class="room-meta-card">
              <div class="room-meta-inline-grid">
                <label class="field room-meta-field">
                  <span>방 이름</span>
                  <input type="text" name="roomName" maxlength="40" placeholder="예: 10번 소망방" required />
                </label>

                <label class="field room-meta-field">
                  <span>인실</span>
                  <input type="number" min="1" max="99" name="roomCapacity" placeholder="예: 6" inputmode="numeric" />
                </label>
              </div>

              <label class="field room-meta-field room-meta-field-wide">
                <span>방 사진 업로드 (선택)</span>
                <input type="file" name="roomImageFile" accept="image/*" />
              </label>

              <label class="field room-meta-field room-meta-field-wide">
                <span>방 설명</span>
                <textarea name="roomDescription" rows="3" placeholder="예: 소그룹 모임, 리더 모임, 상담에 적합"></textarea>
              </label>

              <div class="page-actions compact-actions">
                <button type="submit" class="secondary-button">새 방 추가</button>
              </div>
            </article>
          </div>
        </form>

        <form method="post" action="/admin/settings/rooms" enctype="multipart/form-data" class="settings-room-meta-form">
          <input type="hidden" name="date" value="<%= selectedDate %>" />

          <div class="selection-banner compact-banner">
            <strong>방 기본 정보</strong>
            <span>이름, 인실, 설명, 사진 파일까지 함께 관리합니다. 삭제가 어려운 방은 숨김 처리됩니다.</span>
          </div>

          <div class="room-meta-grid">
            <% schedule.rooms.forEach((room) => { %>
              <article class="room-meta-card">
                <div class="room-meta-card-head room-meta-card-head-space">
                  <div>
                    <strong><%= room.name %></strong>
                    <small><%= room.capacity ? `${room.capacity}인실로 저장됨` : '인실 정보 미설정' %></small>
                  </div>
                  <button
                    type="button"
                    class="ghost-button danger-button"
                    data-delete-room="<%= room.id %>"
                    data-delete-date="<%= selectedDate %>"
                  >
                    방 삭제
                  </button>
                </div>

                <% if (room.imageUrl) { %>
                  <img src="<%= room.imageUrl %>" alt="<%= room.name %> 사진" class="room-meta-preview" referrerpolicy="no-referrer" />
                <% } else { %>
                  <div class="room-meta-preview room-meta-preview-empty">사진 없음</div>
                <% } %>

                <label class="field room-meta-field">
                  <span>방 이름</span>
                  <input
                    type="text"
                    name="name_<%= room.id %>"
                    value="<%= room.name %>"
                    maxlength="40"
                    required
                  />
                </label>

                <label class="field room-meta-field">
                  <span>몇 인실</span>
                  <input
                    type="number"
                    min="1"
                    max="99"
                    name="capacity_<%= room.id %>"
                    value="<%= room.capacity || '' %>"
                    placeholder="예: 6"
                    inputmode="numeric"
                  />
                </label>

                <label class="field room-meta-field room-meta-field-wide">
                  <span>방 설명</span>
                  <textarea
                    name="description_<%= room.id %>"
                    rows="3"
                    placeholder="예: 소그룹 모임, 조용한 상담, 식사 후 교제에 적합"
                  ><%= room.description || '' %></textarea>
                </label>

                <div class="room-meta-inline-grid">
                  <input type="hidden" name="imageUrl_<%= room.id %>" value="<%= room.imageUrl || '' %>" />

                  <label class="field room-meta-field room-meta-field-wide">
                    <span>사진 파일 업로드</span>
                    <input
                      type="file"
                      name="imageFile_<%= room.id %>"
                      accept="image/*"
                    />
                  </label>
                </div>

                <label class="field checkbox-field">
                  <input type="checkbox" name="clearImage_<%= room.id %>" value="1" />
                  <span>사진 제거</span>
                </label>
              </article>
            <% }) %>
          </div>

          <div class="page-actions compact-actions">
            <button type="submit" class="primary-button">방 정보 저장</button>
          </div>
        </form>

        <div class="slot-chip-row">
          <% slotDetails.forEach((slot) => { %>
            <button type="button" class="slot-chip-button <%= slot.id === defaultSlotId ? 'is-active' : '' %>" data-setting-slot-tab="<%= slot.id %>">
              <strong><%= slot.label %></strong>
              <span><%= slot.timeRange %></span>
            </button>
          <% }) %>
        </div>

        <% slotDetails.forEach((slot) => { %>
          <form
            method="post"
            action="/admin/settings/slots/<%= slot.id %>"
            class="settings-panel <%= slot.id === defaultSlotId ? 'is-active' : '' %>"
            data-setting-slot="<%= slot.id %>"
          >
            <input type="hidden" name="date" value="<%= selectedDate %>" />

            <div class="selection-banner compact-banner">
              <strong><%= slot.label %> <%= slot.timeRange %></strong>
              <span><%= slot.detailLabel %></span>
            </div>

            <div class="preset-row">
              <button type="button" class="preset-button" data-apply-mode="available" data-target-slot="<%= slot.id %>">
                전체 예약 가능
              </button>
              <button type="button" class="preset-button" data-apply-mode="fixed" data-target-slot="<%= slot.id %>">
                전체 고정 사용
              </button>
              <button type="button" class="preset-button" data-apply-mode="closed" data-target-slot="<%= slot.id %>">
                전체 운영 안 함
              </button>
            </div>

            <div class="settings-room-list">
              <% slot.rooms.forEach((room) => { %>
                <% const locked = room.status === 'reserved' || room.waitlistCount > 0; %>
                <article class="settings-room-card">
                  <div class="settings-room-head">
                    <strong><%= room.roomName %></strong>
                    <span><%= room.roomCapacity ? `${room.roomCapacity}인실 · ` : '' %><%= room.title %> · <%= room.detail %></span>
                  </div>

                  <div class="mode-group">
                    <label class="mode-pill <%= room.mode === 'available' ? 'is-selected' : '' %>">
                      <input
                        type="radio"
                        name="mode_<%= room.roomId %>"
                        value="available"
                        <%= room.mode === 'available' ? 'checked' : '' %>
                      />
                      예약 가능
                    </label>
                    <label class="mode-pill <%= room.mode === 'fixed' ? 'is-selected' : '' %> <%= locked ? 'is-disabled' : '' %>">
                      <input
                        type="radio"
                        name="mode_<%= room.roomId %>"
                        value="fixed"
                        <%= room.mode === 'fixed' ? 'checked' : '' %>
                        <%= locked ? 'disabled' : '' %>
                      />
                      고정 사용
                    </label>
                    <label class="mode-pill <%= room.mode === 'closed' ? 'is-selected' : '' %> <%= locked ? 'is-disabled' : '' %>">
                      <input
                        type="radio"
                        name="mode_<%= room.roomId %>"
                        value="closed"
                        <%= room.mode === 'closed' ? 'checked' : '' %>
                        <%= locked ? 'disabled' : '' %>
                      />
                      운영 안 함
                    </label>
                  </div>

                  <label class="field fixed-label-field">
                    <span>고정 사용 이름</span>
                    <input
                      type="text"
                      name="label_<%= room.roomId %>"
                      value="<%= room.mode === 'fixed' ? room.label : '' %>"
                      placeholder="예: 비전연구소"
                      data-fixed-label-input
                      <%= room.mode === 'fixed' ? '' : 'disabled' %>
                    />
                  </label>

                  <% if (locked) { %>
                    <p class="locked-note">확정 예약이나 대기 팀이 있어서 지금은 예약 가능 상태를 유지해야 합니다.</p>
                  <% } %>
                </article>
              <% }) %>
            </div>

            <div class="page-actions compact-actions">
              <button type="submit" class="primary-button"><%= slot.label %> 설정 저장</button>
            </div>
          </form>
        <% }) %>
      </section>

      <section class="page-card compact-card" data-page="control">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">RESERVATIONS</p>
            <h2>예약자 명단</h2>
          </div>
        </div>

        <% if (!schedule.confirmedReservations.length) { %>
          <div class="empty-state">현재 확정 예약이 없습니다.</div>
        <% } else { %>
          <div class="management-list">
            <% schedule.confirmedReservations.forEach((reservation) => { %>
              <article class="management-card">
                <div class="management-header">
                  <span class="table-tag">확정</span>
                  <strong><%= reservation.slot.label %> · <%= reservation.roomName %></strong>
                </div>

                <div class="management-title">
                  <strong><%= reservation.communityName %></strong>
                  <span><%= reservation.requesterName %> · <%= reservation.createdAtLabel %></span>
                </div>

                <dl class="management-meta">
                  <div>
                    <dt>연락처</dt>
                    <dd><%= reservation.contact || '-' %></dd>
                  </div>
                  <div>
                    <dt>메모</dt>
                    <dd><%= reservation.note || '-' %></dd>
                  </div>
                </dl>

                <form method="post" action="/admin/reservations/<%= reservation.id %>/cancel">
                  <input type="hidden" name="date" value="<%= selectedDate %>" />
                  <button type="submit" class="danger-button">예약 취소</button>
                </form>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="page-card compact-card" data-page="waitlist">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">WAITLIST</p>
            <h2>방별 대기 명단</h2>
          </div>
        </div>

        <% if (!schedule.hasWaitlist) { %>
          <div class="empty-state">현재 대기 명단은 없습니다.</div>
        <% } else { %>
          <div class="waitlist-grid">
            <% schedule.waitlists.forEach((waitlist) => { %>
              <% if (waitlist.rooms.length || waitlist.legacyItems.length) { %>
                <article class="waitlist-card">
                  <h3><%= waitlist.slot.label %> <span><%= waitlist.slot.timeRange %></span></h3>

                  <% waitlist.rooms.forEach((room) => { %>
                    <div class="room-waitlist-block">
                      <strong><%= room.roomName %><%= room.roomCapacity ? ` · ${room.roomCapacity}인실` : '' %></strong>
                      <ol class="waitlist-list">
                        <% room.items.forEach((reservation, index) => { %>
                          <li><%= index + 1 %>. <%= reservation.communityName %> / <%= reservation.requesterName %></li>
                        <% }) %>
                      </ol>
                    </div>
                  <% }) %>

                  <% if (waitlist.legacyItems.length) { %>
                    <div class="room-waitlist-block">
                      <strong>방 미지정 대기</strong>
                      <ol class="waitlist-list">
                        <% waitlist.legacyItems.forEach((reservation, index) => { %>
                          <li><%= index + 1 %>. <%= reservation.communityName %> / <%= reservation.requesterName %></li>
                        <% }) %>
                      </ol>
                    </div>
                  <% } %>
                </article>
              <% } %>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>

    <script id="admin-state" type="application/json"><%- serializedAdminState %></script>
    <script src="/admin.js" defer></script>
  </body>
</html>
