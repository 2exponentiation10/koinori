<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#752f2f" />
    <title>주일 룸 예약 관리자</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="mobile-app admin-mobile">
    <main class="page-shell">
      <section class="hero hero-admin">
        <div class="hero-copy">
          <p class="eyebrow">KOINORI OPS</p>
          <h1>예약 운영 화면</h1>
          <p class="hero-text">
            모바일 전용 운영 화면입니다. 현황 확인과 취소 처리까지 손가락 터치 기준으로 사용할 수 있습니다.
          </p>
          <% if (adminAuthEnabled) { %>
            <form class="logout-form" method="post" action="/admin/logout">
              <button type="submit" class="secondary-button">로그아웃</button>
            </form>
          <% } %>
        </div>
        <aside class="hero-panel">
          <p class="panel-label">운영 중인 날짜</p>
          <h2><%= selectedDateLabel %></h2>
          <p class="meta-line">현재 시각: <strong><%= currentTimeLabel %></strong></p>
          <p class="meta-line">예약 오픈: <strong><%= bookingOpenAtLabel %></strong></p>
          <div class="status-pill status-<%= bookingStatus.kind %>"><%= bookingStatus.message %></div>
        </aside>
      </section>

      <% if (flashMessage) { %>
        <div class="flash flash-<%= flashLevel %>"><%= flashMessage %></div>
      <% } %>

      <section class="panel" id="date-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">DATE</p>
            <h2>운영 날짜 전환</h2>
          </div>

          <form class="toolbar" method="get" action="/admin">
            <input type="date" name="date" value="<%= selectedDate %>" required />
            <button type="submit" class="secondary-button">날짜 이동</button>
          </form>
        </div>

        <div class="chip-row">
          <% sundayOptions.forEach((option) => { %>
            <a class="date-chip <%= option.selected ? 'date-chip-active' : '' %>" href="/admin?date=<%= option.date %>">
              <span><%= option.label %></span>
              <small>오픈 <%= option.openAtLabel %></small>
            </a>
          <% }) %>
        </div>
      </section>

      <section class="panel" id="summary-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">SUMMARY</p>
            <h2>운영 요약</h2>
          </div>
        </div>

        <div class="summary-strip">
          <article class="summary-card">
            <span>확정 예약</span>
            <strong><%= summary.totalConfirmed %></strong>
            <small>전체 가능 배정 <%= summary.totalCapacity %>건</small>
          </article>
          <article class="summary-card">
            <span>대기 팀</span>
            <strong><%= summary.totalWaitlisted %></strong>
            <small>취소 시 자동 승격</small>
          </article>
          <article class="summary-card">
            <span>남은 방 배정</span>
            <strong><%= summary.remainingAssignments %></strong>
            <small>비어 있는 예약 타임 <%= summary.openSlotCount %>개</small>
          </article>
          <article class="summary-card">
            <span>가동률</span>
            <strong><%= summary.occupancyPercent %>%</strong>
            <small>예약 타임 <%= summary.reservableSlotCount %>개 기준</small>
          </article>
        </div>
      </section>

      <section class="panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">TIMES</p>
            <h2>타임별 현황</h2>
          </div>
        </div>

        <div class="availability-grid availability-grid-readonly">
          <% slotOverview.forEach((slot) => { %>
            <article class="availability-card availability-card-static availability-card-<%= slot.status %>">
              <div class="availability-card-top">
                <div>
                  <p class="card-kicker"><%= slot.label %></p>
                  <h3><%= slot.timeRange %></h3>
                </div>
                <span class="availability-badge"><%= slot.availabilityLabel %></span>
              </div>
              <p class="availability-detail"><%= slot.detailLabel %></p>
              <span class="availability-action"><%= slot.actionLabel %></span>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="panel" id="schedule-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">SCHEDULE</p>
            <h2>방별 예약 현황</h2>
          </div>
        </div>

        <div class="room-grid">
          <% schedule.rooms.forEach((room) => { %>
            <article class="room-card">
              <header>
                <h3><%= room.name %></h3>
              </header>

              <div class="room-slots">
                <% room.slots.forEach((cell) => { %>
                  <div class="slot-row slot-row-<%= cell.type %>">
                    <div class="slot-heading">
                      <strong><%= cell.slot.label %></strong>
                      <span><%= cell.slot.timeRange %></span>
                    </div>

                    <% if (cell.type === 'reserved') { %>
                      <div class="slot-body">
                        <strong><%= cell.reservation.communityName %></strong>
                        <span><%= cell.reservation.requesterName %> · <%= cell.reservation.attendees %>명</span>
                      </div>
                    <% } else if (cell.type === 'fixed') { %>
                      <div class="slot-body">
                        <strong>고정 사용</strong>
                        <span><%= cell.label %></span>
                      </div>
                    <% } else { %>
                      <div class="slot-body slot-empty">
                        <strong>예약 가능</strong>
                        <span>현재 비어 있습니다.</span>
                      </div>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="panel" id="control-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">CONTROL</p>
            <h2>예약 관리</h2>
          </div>
        </div>

        <% if (!schedule.activeReservations.length) { %>
          <div class="empty-state">현재 활성 예약이 없습니다.</div>
        <% } else { %>
          <div class="management-list">
            <% schedule.activeReservations.forEach((reservation) => { %>
              <article class="management-card">
                <div class="management-header">
                  <span class="table-tag"><%= reservation.status === 'confirmed' ? '확정' : '대기' %></span>
                  <strong><%= reservation.slot.label %> · <%= reservation.roomName %></strong>
                </div>

                <div class="management-title">
                  <strong><%= reservation.communityName %> (<%= reservation.attendees %>명)</strong>
                  <span><%= reservation.requesterName %> · <%= reservation.createdAtLabel %></span>
                </div>

                <dl class="management-meta">
                  <div>
                    <dt>연락처</dt>
                    <dd><%= reservation.contact || '-' %></dd>
                  </div>
                  <div>
                    <dt>메모</dt>
                    <dd><%= reservation.note || '-' %></dd>
                  </div>
                </dl>

                <form method="post" action="/admin/reservations/<%= reservation.id %>/cancel">
                  <input type="hidden" name="date" value="<%= selectedDate %>" />
                  <button type="submit" class="danger-button">취소</button>
                </form>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="panel" id="waitlist-panel">
        <div class="section-header">
          <div>
            <p class="eyebrow">WAITLIST</p>
            <h2>타임별 대기 명단</h2>
          </div>
        </div>

        <% if (!schedule.hasWaitlist) { %>
          <div class="empty-state">현재 대기 명단은 없습니다.</div>
        <% } else { %>
          <div class="waitlist-grid">
            <% schedule.waitlists.forEach((waitlist) => { %>
              <article class="waitlist-card">
                <h3><%= waitlist.slot.label %> <span><%= waitlist.slot.timeRange %></span></h3>
                <% if (!waitlist.items.length) { %>
                  <p class="waitlist-empty">대기 없음</p>
                <% } else { %>
                  <ol class="waitlist-list">
                    <% waitlist.items.forEach((reservation, index) => { %>
                      <li>
                        <strong><%= index + 1 %>순위</strong>
                        <span><%= reservation.communityName %> / <%= reservation.requesterName %> / <%= reservation.attendees %>명</span>
                      </li>
                    <% }) %>
                  </ol>
                <% } %>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>
    <nav class="quick-nav quick-nav-admin" aria-label="운영 빠른 이동">
      <a href="#summary-panel">요약</a>
      <a href="#control-panel">관리</a>
      <a href="#waitlist-panel">대기</a>
    </nav>
  </body>
</html>
