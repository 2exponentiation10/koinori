<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= selectedDateLabel %> 방 예약현황표</title>
    <style>
      body {
        font-family: "Pretendard", "Noto Sans KR", sans-serif;
        margin: 24px;
        color: #111827;
      }
      .sheet-head {
        display: grid;
        gap: 8px;
        margin-bottom: 20px;
      }
      .sheet-head strong {
        font-size: 28px;
      }
      .legend {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 18px;
        font-size: 14px;
      }
      .legend span {
        white-space: nowrap;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 12px;
      }
      th, td {
        border: 1px solid #d1d5db;
        padding: 8px 10px;
        text-align: left;
        vertical-align: top;
        font-size: 14px;
      }
      thead th {
        background: #ede0f2;
        text-align: center;
        font-size: 18px;
      }
      tbody th {
        width: 88px;
        background: #faf5fc;
        text-align: center;
      }
      .waitlist {
        margin-top: 24px;
        border: 1px solid #d1d5db;
        background: #faf5fc;
        padding: 12px 16px;
      }
      .waitlist ol {
        margin: 8px 0 0;
        padding-left: 20px;
      }
      @media print {
        body { margin: 12px; }
      }
    </style>
  </head>
  <body>
    <header class="sheet-head">
      <strong><%= selectedDateLabel %> [방 예약현황표]</strong>
      <div>예약 공개 기준: <%= bookingOpenAtLabel %></div>
      <div class="legend">
        <% slotLegend.forEach((slot) => { %>
          <span><strong><%= slot.label %></strong> <%= slot.timeRange %></span>
        <% }) %>
      </div>
    </header>

    <section class="grid">
      <% roomColumns.forEach((columnGroup) => { %>
        <div>
          <% columnGroup.forEach((room) => { %>
            <table>
              <thead>
                <tr>
                  <th colspan="2"><%= room.name %><%= room.capacity ? ` · ${room.capacity}인실` : '' %></th>
                </tr>
              </thead>
              <tbody>
                <% room.slots.forEach((slot) => { %>
                  <tr>
                    <th><%= slot.slotLabel %></th>
                    <td><%= slot.value || "-" %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% }) %>
        </div>
      <% }) %>
    </section>

    <section class="waitlist">
      <strong>대기 명단</strong>
      <% if (!waitlistRows.length) { %>
        <p>현재 대기 명단이 없습니다.</p>
      <% } else { %>
        <ol>
          <% waitlistRows.forEach((row) => { %>
            <li><strong><%= row.slotLabel %></strong> · <%= row.roomName %> · <%= row.order %>순번 · <%= row.communityName %> / <%= row.requesterName %><%= row.contact ? ` / ${row.contact}` : '' %></li>
          <% }) %>
        </ol>
      <% } %>
    </section>

    <script>
      window.addEventListener("load", () => {
        window.print();
      });
    </script>
  </body>
</html>
